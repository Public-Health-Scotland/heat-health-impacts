### Episode map for year
episodes_by_year_plot <- function(year){
  episodes_year <- episodes_marked %>%
    mutate(
      in_episode=ifelse(
        episodes=="FALSE",
        FALSE,
        TRUE
      )
    ) %>%
    filter(
      year(time)==year,
      month(time)>4 & month(time)<10
    ) %>%
    select(time, hb2019name, max_temp_avg, in_episode) %>%
    mutate(
      date=as.Date(time)
    )
  
  plot <- ggplot(episodes_year, aes(x = date, y=hb2019name, fill = in_episode)) +
    geom_tile(color=NA) +
    scale_fill_manual(values = c("TRUE" = phs_colours("phs-purple"), "FALSE" = phs_colours("phs-blue-30"))) +  # Change colors for TRUE/FALSE
    scale_x_date(date_labels = "%b %d", date_breaks = "1 week") +
    scale_y_discrete(labels=label_wrap(20)) +
    theme_minimal() +  # Optional: Use minimal theme for cleaner look
    labs(x = paste("Date (",year,")"), y = "Health Board", fill = "Episode") +
    theme(
      axis.text.x = element_text(angle = 45, hjust = 1),
      axis.ticks.x = element_line(color = "black")
    ) +  # Optional: Rotate x-axis labels for readability
    guides(fill = "none")
  
  return (plot)
}


