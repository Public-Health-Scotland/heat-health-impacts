### Function to plot episodes 
episode_plot <- function(episodes_year){

    healthboard_data <- ed_w_ci_scotland %>%
      filter(
        year(start_date)==episodes_year
      ) %>%
      mutate(
        episode_number=row_number()
      )
  
  healthboard_plot_info <- healthboard_data %>%
    # mutate(
    #   date_key=paste(
    #     paste(format(start_date, format = "%d"), format(start_date, format = "%B"), sep=" "), 
    #     paste(format(end_date, format = "%d"), format(end_date, format = "%B"), sep=" "),  
    #     sep=" - ")
    #   ) %>%
    select(episode_number, excess, lower_bound, upper_bound) %>%
    mutate(
      episode_number=as.character(episode_number)
    ) %>%
    add_row(
      episode_number="Overall",
      excess=sum(healthboard_data$excess),
      lower_bound=excess-(1.96*(sqrt(mean(healthboard_data$var_heat_episode)+mean(healthboard_data$var_baseline)))),
      upper_bound=excess+(1.96*(sqrt(mean(healthboard_data$var_heat_episode)+mean(healthboard_data$var_baseline))))
    )
  
  healthboard_plot <- ggplot(healthboard_plot_info, aes(x = episode_number, y = excess)) +
    geom_col(fill = phs_colours("phs-blue"), color = "black") +  # Plot bars with specified color
    geom_errorbar(aes(ymin = lower_bound, ymax = upper_bound), width = 0.2) +  # Add error bars for CI
    geom_text(aes(label = round(excess,0)), vjust = -0.3, hjust=-0.3) +
    labs(x = "Episode", y = "Excess Deaths") +
    #scale_x_continuous(breaks = seq(min(nhs_lothian_2023_plot_info$episode_number), max(nhs_lothian_2023_plot_info$episode_number), by = 1)) +
    theme_minimal()
  
  return (healthboard_plot)
}

