# Source temperature data and extract average (min and maximum to calculate average)
# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
met_geo_max2 <- read.csv(paste0("/conf/quality_indicators/Climate/data/ephss_data/Final Weather data/",
                                "nearest_station/1Jan2013-31Dec2024_MaxTemperature_nearest_station.csv"), skip = 2) %>%
  rename(max_temperature = Value)
met_geo_max1 <- read.csv(paste0("/conf/quality_indicators/Climate/data/ephss_data/Final Weather data/",
                                "nearest_station/1Jan2003-31Dec2012_MaxTemperature_nearest_station.csv"), skip = 2) %>%
  rename(max_temperature = Value)
met_geo_min <- read.csv(paste0("/conf/quality_indicators/Climate/data/ephss_data/Final Weather data/",
                               "nearest_station/1Jan2013-31Dec2024_MinTemperature_nearest_station.csv"), skip = 2) %>%
  rename(min_temperature = Value)
met_geo_min2 <- read.csv(paste0("/conf/quality_indicators/Climate/data/ephss_data/Final Weather data/",
                                "nearest_station/1Jan2003-31Dec2012_MinTemperature_nearest_station.csv"), skip = 2) %>%
  rename(min_temperature = Value)

# Bind datasets 
met_geo <- bind_rows(met_geo_max1,met_geo_max2)
met_geo_min <- bind_rows(met_geo_min,met_geo_min2)

# Combine max and min temperatures, and tidy dataset
met_geo_combined <- met_geo %>%
  left_join(
    met_geo_min,
    by=c("Latitude", "Longitude", "Site.identifier", "Time"))

met_geo <- met_geo_combined %>%
  rename(InterZone = Site.identifier) %>%
  rename(time = Time) %>%
  mutate(mean_temperature=(max_temperature+min_temperature)/2,
         year = year(time)) %>%
  select(-c(Latitude, Longitude))

met_geo$time <- as.POSIXct(met_geo$time, format = "%Y-%m-%d %H:%M:%S", tz = "UTC")

# 2 - Episode extraction - Health board level ------------------------------------------

# Join Temperature with Health board and get average max temp for HB on that day
met_geo_w_hb <- met_geo %>%
  left_join(
    distinct(postcode_dir[ , c("intzone2011", "hb2019name")]),
    by=c("InterZone"="intzone2011"),
  ) %>%
  filter(year %in% c(2005:2025))%>%
  select(-InterZone) %>%
  group_by(time, hb2019name) %>%
  summarise(
    max_temp_avg=max(mean_temperature) # get average temp across HB for each day
  ) %>%
  ungroup()


### Calculate episodes for each HB
# An episode is any day or group of days above 20degrees and the day before and after

# Lazy approached use which assumes no heatwaves in winter
# Flag days above 20 degrees and arrange by HB and date
met_geo_w_hb_flagged <- met_geo_w_hb %>%
  mutate(
    at_least_20=max_temp_avg>=ref_temp
  ) %>%
  arrange(hb2019name, time)

# Find episodes marking each day based on it's temp or previous/next day temp
episodes_marked <- met_geo_w_hb_flagged %>%
  mutate(
    lagged=lag(at_least_20),
    leaded=lead(at_least_20)
  ) %>%
  mutate(episodes=case_when(
    at_least_20 ~ "HOT",
    lagged & leaded ~ "HOT",
    lagged ~ "LAG",
    leaded ~ "LEAD",
    .default = "FALSE"
  ))%>%
  mutate(time = as.Date(time))

# Remove non episodes and number the episodes
episodes <- episodes_marked %>%
  filter(episodes!="FALSE") %>%
  mutate(
    episode_number=cumsum(episodes=="LEAD")
  )

# Heat episodes beginning per year
episodes_year <- episodes %>%
  mutate(year=year(time)) %>%
  select(year, episodes) %>%
  filter(episodes=="LEAD") %>%
  group_by(year) %>%
  summarise(n=n())

# Heat episodes per HB
episodes_hb <- episodes %>%
  select(hb2019name, episodes) %>%
  filter(episodes=="LEAD") %>%
  group_by(hb2019name) %>%
  summarise(n=n())

hbs <- tibble(hb2019name = unique(met_geo_w_hb$hb2019name))

episodes_hb <- hbs  %>%
  left_join(episodes_hb, by = "hb2019name") %>%
  mutate(n = replace_na(n, 0))

# Heat episodes beginning per year and HB
episodes_year_hb <- episodes %>%
  mutate(year=year(time)) %>%
  select(hb2019name, year, episodes) %>%
  filter(episodes=="LEAD") %>%
  group_by(hb2019name, year) %>%
  summarise(n=n())


