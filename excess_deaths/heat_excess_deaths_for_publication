# daily deaths and merge
daily_deaths_scotland <- deaths_df %>%
  group_by(date) %>%
  summarise(
    death=sum(death)
  )

deaths_df_w_episode_scotland <- daily_deaths_scotland %>%
  left_join(
    episodes_marked_scotland_level[,c("time", "episodes")],
    by=c("date"="time")
  ) %>%
  drop_na(episodes) %>%
  arrange(date) %>%
  mutate(
    not_in_episode=ifelse(
      episodes=="FALSE",
      TRUE,
      FALSE
    )
  ) %>%
  select(date, death, not_in_episode)

# Calculate the baseline deaths
# This is total death 14 days before and 14 days after an episode, missing out
# any days which are part of an episode. It only checks the last/next 28 days,
# and will use less than 14 days if needed
deaths_df_w_episode_scotland <- deaths_df_w_episode_scotland %>%
  mutate(
    last_14_days_deaths = sapply(1:n(), function(i){
      start_idx <- max(1, i-28)
      valid_indices <- which(not_in_episode[start_idx:(i-1)])+(start_idx-1)
      valid_values <- death[valid_indices]
      sum(tail(valid_values,14))
    }),
    last_14_days_count = sapply(1:n(), function(i){
      start_idx <- max(1, i-28)
      sum(not_in_episode[start_idx:(i-1)])
    }),
    next_14_days_deaths = sapply(1:n(), function(i){
      end_idx <- min(n(), i+28)
      valid_indices <- which(not_in_episode[(i+1):end_idx])+i
      valid_values <- death[valid_indices]
      sum(head(valid_values,14))
    }),
    next_14_days_count = sapply(1:n(), function(i){
      end_idx <- min(n(), i+28)
      sum(not_in_episode[(i+1):end_idx])
    }),
  ) %>%
  mutate(
    last_14_days_count=ifelse(
      last_14_days_count<14,
      last_14_days_count,
      14
    ),
    next_14_days_count=ifelse(
      next_14_days_count<14,
      next_14_days_count,
      14
    )
  )

# Join deaths into episodes
episodes_scotland_deaths <- episodes_scotland %>%
  left_join(
    deaths_df_w_episode_scotland[ , c("date", "death", "last_14_days_deaths",
                                      "last_14_days_count", "next_14_days_deaths",
                                      "next_14_days_count")],
    by=c("time"="date")
  )

### Transform Dataset
# Summarise data for each episode
episodes_scotland_deaths_transform <- episodes_scotland_deaths %>%
  group_by(episode_number) %>%
  summarise(
    length=n(),
    start_date=first(time),
    end_date=last(time),
    deaths=sum(death),
    last_14_days_deaths=first(last_14_days_deaths),
    next_14_days_deaths=last(next_14_days_deaths),
    last_14_days_count=first(last_14_days_count),
    next_14_days_count=last(next_14_days_count),
    highest_temp=max(max_temp_avg)
  )


### Calculate excess deaths
excess_deaths_scotland <- episodes_scotland_deaths_transform %>%
  mutate(
    avg_daily_deaths=deaths/length,
    avg_baseline_deaths=(last_14_days_deaths+next_14_days_deaths)/(last_14_days_count+next_14_days_count),
    avg_daily_excess_deaths=avg_daily_deaths-avg_baseline_deaths
  )

### Confidence intervals
# Calculate an overdispersion parameter phi for summer deaths outside of heat episodes. We do this by:
# a.	excluding any heat episode days from the daily deaths series
# b.	calculating Variance/Mean of daily deaths for each month May to September
# c.	averaging the five values from May to September

ci_deaths_scotland <- deaths_df_w_episode_scotland %>%
  select(date, death, not_in_episode) %>%
  mutate(month=month(date), year=year(date)) %>%
  filter(
    not_in_episode,
    month>4 & month<10) %>%
  group_by(year, month) %>%
  summarise(
    mean=mean(death),
    variance=var(death)
  ) %>%
  group_by(year) %>%
  summarise(
    ci_mean=mean(mean),
    ci_variance=mean(variance)
  )


## Add in CI 
ed_w_ci_scotland <- excess_deaths_scotland %>%
  mutate(
    year=year(start_date)
  ) %>%
  left_join(
    ci_deaths_scotland[,],
    by=c("year"="year")
  ) %>%
  mutate(
    var_heat_episode=avg_daily_deaths*ci_mean/length,
    var_baseline=avg_baseline_deaths*ci_mean/(last_14_days_count+next_14_days_count),
    se=sqrt(var_heat_episode+var_baseline),
    ci=1.96*se,
    excess=avg_daily_excess_deaths*length,
    lower_bound=excess-ci,
    upper_bound=excess+ci
  )

